# CookGenie — Environment Variables
# Copy to .env.local and fill in values, or run `vercel env pull .env.local`

# Neon PostgreSQL (via Vercel Marketplace)
DATABASE_URL=

# AI Gateway (auto-provisioned via `vercel env pull`)
# VERCEL_OIDC_TOKEN=
# AI_GATEWAY_API_KEY=

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
# For local dev: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js secret — generate with: openssl rand -base64 32
# In production, Vercel auto-generates this via `vercel env add AUTH_SECRET`
AUTH_SECRET=
